; =====================================================
; Remove_'Open in Terminal'_from_Context_Menu
; =====================================================


; Remove 'Open in Terminal' from Context Menu
; Created by: Sergey Tkachenko
; Tutorial: https://winaero.com/how-to-remove-open-in-windows-terminal-context-menu-in-windows-11/

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Shell Extensions\Blocked]
"{9F156763-7844-4DC4-B2B1-901F640F5155}"=""

; =====================================================
; Set Pin Lenth to 4 Characters
; =====================================================


; Set Pin Lenth to 4 Characters
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\PassportForWork\PINComplexity]
"MinimumPINLength"=dword:00000004

; Enable Compact View
[HKEY_CURRENT_USER\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced]
"UseCompactMode"=dword:00000001

; =====================================================
; Defender Removal
; =====================================================

; Start > Windows Security > Virus & threat protection > Disabled
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows Defender]
"DisableAntiSpyware"=dword:00000001

; Start > Windows Security > Virus & threat protection > Manage settings > Real-time protection > Disabled
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection]
"DisableRealtimeMonitoring"=dword:00000001

; Start > Windows Security > Virus & threat protection > Manage settings > Real-time protection > Off
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Real-Time Protection]
"DisableRealtimeMonitoring"=dword:00000001

; Start > Windows Security > Virus & threat protection > Manage settings > Cloud-delivered protection > Off
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Spynet]
"SpyNetReporting"=dword:00000000

; Start > Windows Security > Virus & threat protection > Manage settings > Automatic sample submission > Off
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Spynet]
"SubmitSamplesConsent"=dword:00000000

; Start > Windows Security > Virus & threat protection > Manage settings > Tamper Protection > Off
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Features]
"TamperProtection"=dword:00000004

; Start > Windows Security > Virus & threat protection > Manage ransomware protection > Controlled folder access > Off
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Windows Defender Exploit Guard\Controlled Folder Access]
"EnableControlledFolderAccess"=dword:00000000

; Start > Windows Security > Account protection > Dismiss notification
[HKEY_CURRENT_USER\SOFTWARE\Microsoft\Windows Security Health\State]
"AccountProtection_MicrosoftAccount_Disconnected"=dword:00000000

; Start > Windows Security > Firewall & network protection > Domain network > Microsoft Defender Firewall > Disabled
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\WindowsFirewall\DomainProfile]
"EnableFirewall"=dword:00000000

; Start > Windows Security > Firewall & network protection > Domain network > Microsoft Defender Firewall > Off
[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Services\SharedAccess\Parameters\FirewallPolicy\DomainProfile]
"EnableFirewall"=dword:00000000

; Start > Windows Security > Firewall & network protection > Private network > Microsoft Defender Firewall > Disabled
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\WindowsFirewall\PrivateProfile]
"EnableFirewall"=dword:00000000

; Start > Windows Security > Firewall & network protection > Private network > Microsoft Defender Firewall > Off
[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Services\SharedAccess\Parameters\FirewallPolicy\StandardProfile]
"EnableFirewall"=dword:00000000

