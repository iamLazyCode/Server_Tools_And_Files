Windows Registry Editor Version 5.00

; =====================================================
; Allow scripts in CMD
; =====================================================


; POWERSHELL
; Allow scripts in CMD set-executionpolicy remotesigned
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\PowerShell\1\ShellIds\Microsoft.PowerShell]
"Path"="C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
"ExecutionPolicy"="RemoteSigned"

[HKEY_LOCAL_MACHINE\SOFTWARE\Wow6432Node\Microsoft\PowerShell\1\ShellIds\Microsoft.PowerShell]
"Path"="C:\\Windows\\SysWOW64\\WindowsPowerShell\\v1.0\\powershell.exe"
"ExecutionPolicy"="RemoteSigned"

; =====================================================
; Disable Snap Layouts On Hover
; =====================================================


; Disable Snap Layouts On Hover
; Created by Ryan Maskell
; Article: https://winbuzzer.com/2021/12/06/windows-11-disable-the-snap-layouts-pop-up-on-the-maximize-button-xcxwbt/

[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced]
"EnableSnapAssistFlyout"=dword:00000000

; =====================================================
; Enable Linked Connections
; =====================================================


; Enable Linked Connections
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System]
"EnableLinkedConnections"=dword:00000001

; =====================================================
; Enable Samba Warning Error Fix
; =====================================================


; Enable Samba Warning Error Fix
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Internet Settings\ZoneMap\Ranges\Range1]
"*"=dword:00000001
":Range"="192.168.50.*"

