; How to Add New Windows Batch File to the Windows 10 Context Menu
[HKEY_CLASSES_ROOT\.bat\ShellNew]
"NullFile"=""

; To Enable Developer Mode By Default
[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows\Appx]
"AllowDevelopmentWithoutDevLicense"=dword:00000001

; Disable menu show delay
; [HKEY_CURRENT_USER\Control Panel\Desktop]
; "MenuShowDelay"="0"

; Show Drive Letter First
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer]
"ShowDriveLettersFirst"=dword:00000004

; How to Show More Details in File Explorer Transfer Dialog
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer\OperationStatusManager]
"EnthusiastMode"=dword:00000001

; How to Add 'Empty Recycle Bin Context Menu' in Windows 10 & 11 
[HKEY_CLASSES_ROOT\Directory\Background\shell\empty]
"CommandStateHandler"="{c9298eef-69dd-4cdd-b153-bdbc38486781}"
"Description"="@shell32.dll,-31332"
"Icon"="shell32.dll,-254"
"MUIVerb"="@shell32.dll,-10564"
"Position"="Bottom"
[HKEY_CLASSES_ROOT\Directory\Background\shell\empty\command]
"DelegateExecute"="{48527bb3-e8de-450b-8910-8c4099cb8624}"

; Disable Tooltip Off Mouse Hover
; https://www.elevenforum.com/t/disable-tooltip-popups.10660/
[HKEY_CURRENT_USER\Control Panel\Mouse]
"MouseHoverTime"="6000"

; Disable Drive Automatic Encryption
[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Control\BitLocker]
"PreventDeviceEncryption"=dword:00000001

; Adding LocalSend in Right Click for Uniget

[HKEY_CLASSES_ROOT\*\shell\SendToLocalSend]
"MUIVerb"="Send to LocalSend"
"Icon"="C:\\Users\\LazyCode\\AppData\\Local\\Programs\\LocalSend\\localsend_app.exe,0"

[HKEY_CLASSES_ROOT\*\shell\SendToLocalSend\command]
@="\"C:\\Users\\LazyCode\\AppData\\Local\\Programs\\LocalSend\\localsend_app.exe\" \"%1\""

; Show BSOD details instead of sad smiley
[HKEY_LOCAL_MACHINE\System\CurrentControlSet\Control\CrashControl]
"DisplayParameters"=dword:00000001
"DisableEmoticon"=dword:00000001

